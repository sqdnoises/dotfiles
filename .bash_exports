#!/usr/bin/env bash

# WSL
if grep -qEi "(Microsoft|WSL)" /proc/version 2>/dev/null; then
    export EDITOR="code"
else
    export EDITOR="nano"
fi

# Useful exports
export HISTSIZE=10000
export HISTFILESIZE=20000
export HISTCONTROL=ignoreboth:erasedups

# Paths
if [ -d "$HOME/.local/bin" ] ; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# Set a custom prompt
# export PS1=""
